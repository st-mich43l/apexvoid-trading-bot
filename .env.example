# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
SIGNAL_VIP_CHANNEL_ID=-100123456789
# Manual signal broadcast channel used by the general bot. The dedicated
# signal bot sends scanner and auto-trade events only to TELEGRAM_OWNER_ID.
SIGNAL_PUBLIC_CHANNEL_ID=
# Show per-signal pip results publicly; aggregate stats always remain private
SIGNAL_PUBLIC_SHOW_PIPS=true

# Owner lock — your Telegram user ID. Only this user can DM the bot.
# Required to enable the privileged DM interface; unset denies all DMs.
TELEGRAM_OWNER_ID=123456789

# Chart screenshot analysis via Claude vision (optional)
ANTHROPIC_API_KEY=sk-ant-...

# Timezone used when daily signal numbers reset
SEQ_RESET_TZ=Asia/Ho_Chi_Minh
# Local-hour boundaries used by /stats session grouping
SESSION_ASIA_START=22
SESSION_LONDON_START=7
SESSION_NY_START=13
# Metals daily rollover / NY futures close in UTC
DAILY_ROLLOVER_UTC_HOUR=21

# Legacy bare "+N pips" channel booking (disabled by default)
AUTO_BOOK_BARE_PIPS=false

# Notify-only price watcher. Reads closed M1 bars from ctrader-feed's Redis
# window first; TIINGO_API_KEY is only a fallback for a feed gap and can be
# left unset (the watcher still runs, it just has no fallback then).
TIINGO_API_KEY=
# Seconds between price checks while filled signals exist. Under normal
# operation this only polls the cTrader Redis bar window (cheap, no Tiingo
# calls). Tiingo free tier caps at 50 req/hour and 1000 req/day - if the
# cTrader feed is down for an extended period, 30s means Tiingo fallback
# calls run at ~120/hour, over the free-tier cap for the outage's duration;
# accepted tradeoff for faster TP/SL notifications the rest of the time.
TRACK_INTERVAL=30
# If the newest ctrader-feed M1 bar is older than this, fall back to Tiingo
# for that tick instead. ~3x the M1 interval tolerates one missed close.
WATCHER_CTRADER_STALE_SECONDS=180

# Enable once-daily ForexFactory economic-calendar ingestion
CALENDAR_ENABLED=true
# ForexFactory machine-readable weekly feed URLs
CALENDAR_FEED_THISWEEK=https://nfs.faireconomy.media/ff_calendar_thisweek.json
CALENDAR_FEED_NEXTWEEK=https://nfs.faireconomy.media/ff_calendar_nextweek.json
# Identifying User-Agent sent with calendar downloads
CALENDAR_USER_AGENT=apexvoid-trading-bot/1.0 (+contact)
# Comma-separated high-impact currencies retained
CALENDAR_CURRENCIES=USD
# Comma-separated oil-event title keywords
OIL_KEYWORDS=crude oil inventories,opec,cushing,api weekly crude
# Local hour for the daily calendar sync and morning brief
NEWS_BRIEF_HOUR=7
# Hours ahead checked from the local database before posting an entry
EVENT_GUARD_HOURS=4
# Refuse guarded entries instead of adding a warning tag
NEWS_GUARD_BLOCK=false

# Sunday VIP-only weekly performance recap (Mon=0 … Sun=6)
WEEKLY_REPORT_ENABLED=true
WEEKLY_REPORT_DOW=6
WEEKLY_REPORT_HOUR=8
# Skip the recap when the closed trading week has no results
WEEKLY_REPORT_SKIP_EMPTY=false

# cTrader Open API feed and optional demo-only ApexVoid Algo executor
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCESS_TOKEN=
CTRADER_REFRESH_TOKEN=
CTRADER_ACCOUNT_ID=
CTRADER_HOST=demo.ctraderapi.com
CTRADER_PORT=5035
CTRADER_SYMBOL=XAUUSD
CTRADER_TIMEFRAMES=M1,M5,M15,M30
CTRADER_BACKFILL_BARS=1500
CTRADER_REQUEST_TIMEOUT=30
# Refresh access tokens ahead of expiry; the file mirrors rotated credentials off Redis.
CTRADER_TOKEN_REFRESH_LEAD_DAYS=5
CTRADER_TOKEN_CHECK_INTERVAL_HOURS=6
CTRADER_REFRESH_TOKEN_KEY=ctrader:refresh_token
CTRADER_REFRESH_TOKEN_FILE=/var/lib/apexvoid/ctrader-token.json
REDIS_URL=redis://redis:6379/0
BARS_WINDOW_MAX=1500
BARS_CHANNEL=bars:new
# Warn when this many live bars consecutively close at the same range extreme.
BAR_QUALITY_LOOKBACK=6
HEALTH_FILE=/tmp/ctrader-feed.heartbeat

# ApexVoid Algo demo executor. Keep disabled/dry-run until --account-check confirms the
# token has Trading scope and the selected FP Markets account is demo and Hedged.
AUTO_TRADE_ENABLED=true
AUTO_TRADE_DRY_RUN=false
# Runtime contract. demo_eval is permissive only after the broker confirms a
# demo account; the executor terminates before ordering if that account is live.
AUTO_TRADE_PROFILE=demo_eval
AUTO_TRADE_REQUIRE_DEMO_ACCOUNT=true
AUTO_TRADE_ALLOW_CONCURRENT_STRATEGIES=true
AUTO_TRADE_ALLOW_HEDGED_XAU=true
AUTO_TRADE_REQUIRE_FLAT_FOR_RANGE=false
AUTO_TRADE_RANGE_ENABLED=true
AUTO_TRADE_RANGE_TWO_SIDED_ENABLED=true
AUTO_TRADE_BREAKOUT_ENABLED=true
AUTO_TRADE_RETEST_ENABLED=true
AUTO_TRADE_REACTION_ENABLED=true
AUTO_TRADE_LIQUIDITY_REVERSAL_ENABLED=true
AUTO_TRADE_MULTI_MATCH_ENABLED=true
AUTO_TRADE_ALLOW_COUNTER_BIAS=true
AUTO_TRADE_TRACK_ALL_STRUCTURAL_MATCHES=true
AUTO_TRADE_CANDIDATE_CONTRACT_VERSION=5
AUTO_TRADE_CANONICAL_SYMBOL=XAU
# Hardening switch: refuse auto-trade when the token grants any live account.
AUTO_TRADE_REQUIRE_DEMO_ONLY_TOKEN=false
AUTO_TRADE_SYMBOLS=XAU
AUTO_TRADE_EXPECTED_BROKER=fpmarkets
AUTO_TRADE_SL_DISTANCE=6.5
AUTO_TRADE_RISK_PCT=2.0
# Choose min, table, or risk. Deployment uses the operator equity table.
AUTO_TRADE_SIZING_MODE=table
# XAUUSD execution units: one strategy pip is 0.1 price for a 100 oz contract.
AUTO_TRADE_XAU_PIP_SIZE=0.1
AUTO_TRADE_XAU_CONTRACT_SIZE=100
AUTO_TRADE_PIP_VALUE_PER_LOT=10.0
AUTO_TRADE_TARGET_PLANS_PIPS=30,60,90,120,200
# 0.02 exits at TP1/TP3; 0.03 at TP1-TP3; 0.04 at TP1-TP4; >=0.05 uses all five.
AUTO_TRADE_TP_WEIGHTS=20,20,20,20,20
# Adaptive range-scalp target ladder (app/autotrade/range_targets.py,
# AutoTradeOptions.EffectiveRangeTargetsPips on the C# side - same env var,
# single source of truth). Previously hardcoded to exactly 50 or 70 pips in
# five separate places; any setup with 0-49 pips of room to the opposite
# range edge (the common case) silently produced no executable candidate at
# all. The largest configured target that fits (target + buffer <= room) is
# selected; if none fit, the setup stays analysis-only with a persisted
# insufficient_target_room reason instead of vanishing silently.
AUTO_TRADE_RANGE_TARGETS_PIPS=20,30,40,50,70
AUTO_TRADE_RANGE_TP_BUFFER_PIPS=3
AUTO_TRADE_RANGE_MIN_TARGET_PIPS=20
AUTO_TRADE_RANGE_MIN_RR=1.10
# Structure-aware barrier / range controls (shadow-safe; each has a kill switch).
SCALP_BARRIER_FALLBACK_ENABLED=true
SCALP_BARRIER_FALLBACK_MIN_CONFIRMATIONS=1
SCALP_RANGE_PROVISIONAL_ENABLED=true
SCALP_POST_IMPULSE_RANGE_ENABLED=true
RANGE_SCALP_MIN_INSIDE_CLOSES=3
RANGE_SCALP_MAX_EDGE_WIDTH_ATR=0.75
# Multi-strategy routing (legacy single key still written for compatibility).
SCANNER_TOP_N=0
AUTO_TRADE_MAX_TRACKED_CANDIDATES=0
AUTO_TRADE_MAX_ACTIVE_POSITIONS_PER_SYMBOL=0
# Quality tiers — frequency via Tier B at reduced risk, not by raising base risk.
AUTO_TRADE_TIER_A_RISK_MULTIPLIER=1.0
AUTO_TRADE_TIER_B_RISK_MULTIPLIER=0.5
AUTO_TRADE_POST_IMPULSE_RISK_MULTIPLIER=0.5
AUTO_TRADE_ONE_SIDED_RANGE_RISK_MULTIPLIER=0.5
# Market Map execute tolerance (bid/ask + ATR/bar rounding only).
AUTO_TRADE_MAP_EXECUTE_TOLERANCE_PIPS=3
AUTO_TRADE_MAP_EXECUTE_TOLERANCE_ATR=0.15
# Reaction-aware entry drift: latency floor + ATR adaptation + hard cap.
AUTO_TRADE_RANGE_MIN_ENTRY_DRIFT_PIPS=10
AUTO_TRADE_MAP_MIN_ENTRY_DRIFT_PIPS=10
AUTO_TRADE_TREND_MIN_ENTRY_DRIFT_PIPS=15
AUTO_TRADE_RANGE_MAX_ENTRY_DRIFT_ATR=1.0
AUTO_TRADE_MAP_MAX_ENTRY_DRIFT_ATR=1.0
AUTO_TRADE_TREND_MAX_ENTRY_DRIFT_ATR=1.5
AUTO_TRADE_RANGE_HARD_ENTRY_DRIFT_PIPS=20
AUTO_TRADE_MAP_HARD_ENTRY_DRIFT_PIPS=20
AUTO_TRADE_TREND_HARD_ENTRY_DRIFT_PIPS=30
# Zone-fill geometry: fall back to single-entry instead of rejecting inside-zone.
AUTO_TRADE_ZONE_FILL_FALLBACK_ENABLED=true
AUTO_TRADE_INSIDE_ZONE_MARKET_ENTRY_ENABLED=true
AUTO_TRADE_BE_BUFFER_PIPS=6
AUTO_TRADE_CANDIDATE_MAX_AGE_SECONDS=420
AUTO_TRADE_CANDIDATE_STORAGE_TTL_SECONDS=604800
AUTO_TRADE_SPOT_MAX_AGE_SECONDS=5
AUTO_TRADE_MAX_SPREAD_PIPS=5
AUTO_TRADE_MAX_ENTRY_DISTANCE_PIPS=10
AUTO_TRADE_MIN_CONFLUENCE=2
AUTO_TRADE_POLL_MS=1000
AUTO_TRADE_CANDIDATE_STREAM=auto_trade:candidates
AUTO_TRADE_EVENT_STREAM=auto_trade:events
AUTO_TRADE_LABEL=apexvoid-auto
AUTO_TRADE_STREAM_MAXLEN=1000
AUTO_TRADE_NEWS_GUARD_MINUTES=30
# Retire a confirmed broken range box for four hours.
AUTO_TRADE_BOX_RETIRE_SECONDS=14400
# Scanner detectors already own the strategy decision. Transport the strongest
# completed M5 match to ApexVoid Algo without a second regime/M1 confirmation.
AUTO_TRADE_STRATEGY_MATCH_ENABLED=true
AUTO_TRADE_STRATEGY_MATCH_MAX_AGE_SECONDS=420
# Trade an HTF-aligned structural Market Map zone after an M1 touch/rejection.
AUTO_TRADE_MAPPED_ZONE_ENABLED=false
# Track distant mapped zones as working targets; only the tighter execute
# window may produce an immediate market entry after M1 touch + rejection.
AUTO_TRADE_MAP_TRACK_DISTANCE_ATR=8.0
AUTO_TRADE_MAP_EXECUTE_DISTANCE_ATR=1.5
# Closed M1 bars searched for touch → rejection/reclaim (latest bar need not touch).
AUTO_TRADE_MAP_REACTION_LOOKBACK_BARS=5
AUTO_TRADE_MAP_REACTION_REARM_BARS=3
AUTO_TRADE_MAP_REACTION_REARM_ATR=0.50
# One active initial group per mapped-zone thesis (independent of reaction_id).
AUTO_TRADE_MAP_THESIS_LOCK_ENABLED=true
# Ignore collapsed map bands before they can become an unreachable target.
# Effective minimum width = max(ATR multiple, absolute price units).
AUTO_TRADE_MAP_ZONE_MIN_WIDTH_ATR=0.15
AUTO_TRADE_MAP_ZONE_MIN_WIDTH_ABS=1.0
# Quality-gated mean reversion against HTF bias.
AUTO_TRADE_MAP_COUNTER_BIAS_ENABLED=true
AUTO_TRADE_MAP_COUNTER_BIAS_MIN_SCORE=6.0
AUTO_TRADE_MAP_COUNTER_BIAS_MIN_CONFLUENCE=2
# Directional chop→trend override. Ships dark; read
# auto_trade:regime_compare:{symbol} for 48h before enabling.
AUTO_TRADE_REGIME_DIRECTION_ENABLED=false
AUTO_TRADE_REGIME_DIRECTION_LOOKBACK=120
AUTO_TRADE_REGIME_MIN_DIRECTIONAL_SWINGS=3
AUTO_TRADE_REGIME_MIN_DISPLACEMENT_ATR=4.0
# Refuse a box entry when its structure stop makes reward/risk weaker than 1.25.
AUTO_TRADE_BOX_MIN_RR=1.25
# Momentum scale-in uses realised balance, never floating equity. Adds are
# independent positions and averaging down is hard-refused.
AUTO_TRADE_MAX_TRANCHES=2
AUTO_TRADE_ADD_RISK_FRACTION=0.5
AUTO_TRADE_ADD_MAX_AGE_BARS=3
AUTO_TRADE_ADD_COOLDOWN_BARS=3
AUTO_TRADE_ADD_LEVEL_BUFFER_ATR=1.0
AUTO_TRADE_ADD_STOP_BUFFER_ATR=0.3
AUTO_TRADE_ADD_MIN_STOP_PIPS=30
# Clear the sweep wick by this ATR fraction before placing an autonomous SL.
AUTO_TRADE_WICK_STOP_BUFFER_ATR=0.15
# Demo evaluation supports independent hedged rails; on a confirmed non-hedged
# demo account the executor reports capability fallback and close-and-reverses.
AUTO_TRADE_RANGE_FLIP_ENABLED=true
AUTO_TRADE_NON_HEDGED_OPPOSITE_POLICY=broker_netting
AUTO_TRADE_FLIP_EXIT_BUFFER_PIPS=10
AUTO_TRADE_FLIP_CONFIRM_TIMEOUT_SECONDS=30
AUTO_TRADE_ADD_REQUIRE_RISK_FREE=false
# Split qualifying zones only when the planned size supports useful legs.
AUTO_TRADE_ZONE_FILL_ENABLED=true
AUTO_TRADE_ZONE_FILL_MIN_LOTS=0.09
AUTO_TRADE_ZONE_FILL_MIN_ATR=0.5
AUTO_TRADE_ZONE_FILL_TTL_BARS=3
# Structure-stop band used for trend-family candidates only (box/legacy
# candidates keep using AUTO_TRADE_ADD_MIN_STOP_PIPS/AUTO_TRADE_SL_DISTANCE).
AUTO_TRADE_TREND_STOP_MIN_PIPS=40
AUTO_TRADE_TREND_STOP_MAX_PIPS=65
# Trade-quality guards added after the 22 Jul 2026 incident. EQ exclusion and
# edge proximity apply to box-scalp candidates only.
AUTO_TRADE_EQ_EXCLUSION_FRACTION=0.15
AUTO_TRADE_EDGE_PROXIMITY_ATR=0.5
# When a candidate's structure stop lands inside the nearest opposing HTF
# supply/demand zone: push it beyond the zone (true) or reject the candidate
# (false).
AUTO_TRADE_STOP_PUSH_BEYOND_ZONE=true
# HTF supply/demand veto (worker.py only). Kill switch so it can be disabled
# without a redeploy if it proves too strict.
AUTO_TRADE_HTF_VETO_ENABLED=true
# Demo evaluation observes structural quality and only hard-blocks technical
# invalidity. Conservative/live deployments may select balanced/strict.
AUTO_TRADE_STRUCTURAL_GUARD_MODE=observe
# Legacy enforcement switches remain explicit. In observe mode the worker
# still measures these conditions without terminally discarding a setup.
AUTO_TRADE_OPPOSING_BARRIER_VETO_ENABLED=false
AUTO_TRADE_OPPOSING_BARRIER_ATR=0.5
# Post-stop-out cooldown (23 Jul 2026 incident: a stopped-out zone was
# re-entered same-direction 15 minutes later at essentially the same price).
# Only a confirmed broker stop-loss is enforceable. Manual/external/unknown
# reconciliation closes remain warning-only records.
AUTO_TRADE_ZONE_COOLDOWN_ENABLED=false
AUTO_TRADE_ZONE_COOLDOWN_MINUTES=60
AUTO_TRADE_ZONE_COOLDOWN_ATR=1.0
# Overlapping opposing Market Map zones (23 Jul incident: published SELL
# 4,116-4,127 and BUY 4,112-4,122 overlapped 4,116-4,122; the fill landed
# inside it). Trade-time veto only - Market Map output/zones.py untouched.
AUTO_TRADE_OVERLAP_VETO_ENABLED=false
# Shadow reconciliation publishes comparison metrics while strategies keep
# the original zone set. Use enforce only after reviewing those deltas.
AUTO_TRADE_ZONE_RECONCILE_ENABLED=true
AUTO_TRADE_ZONE_RECONCILE_MODE=shadow
# Trend/breakout regime classifier (telegram-bot/app/autotrade/trend.py).
# demo_eval runs trend and counter-direction local structures together.
AUTO_TRADE_TREND_ENABLED=true
TREND_MIN_BOS=2
TREND_MIN_HEIGHT_ATR=3.0
TREND_ATR_EXPANSION=1.15
TREND_ATR_BASELINE_BARS=48
# Never enter a continuation at market before price retests the broken level.
TREND_ALLOW_CHASE=false
TREND_LEVEL_BUFFER_ATR=1.0
TP_MIN_SPACING_ATR=0.5
TREND_BREAKOUT_MAX_AGE_BARS=5
TREND_BREAKOUT_ACCEPT_BARS=2
# TP1 is 30 pips; require another 5 pips before the nearest prior barrier.
TREND_BREAKOUT_MIN_ROOM_PIPS=35
REACTION_MAX_ATR=0.5
REGIME_CHOP_ALERT_SHARE=0.75

# `/ algo` DM suffix on a manual signal — owner opt-in per signal to also arm
# cTrader broker-side execution using the owner's exact entered SL/TP, instead
# of staying notify-only. Independent of the AUTO_TRADE_* engine above (own
# signal source, own stop policy). ctrader-engine now consumes
# MANUAL_TRADE_INTENT_STREAM (via the auto_trade:candidates bridge) and
# MANUAL_TRADE_COMMAND_STREAM (owner-override /trade_close/_sl/_cancel), so a
# real (demo) broker order can be placed once MANUAL_ALGO_ENABLED=true.
MANUAL_ALGO_ENABLED=false
MANUAL_ALGO_DRY_RUN=true
MANUAL_ALGO_RISK_PCT=2.0
MANUAL_TRADE_INTENT_STREAM=manual_trade:intents
MANUAL_TRADE_INTENT_STREAM_MAXLEN=1000
MANUAL_TRADE_COMMAND_STREAM=manual_trade:commands
MANUAL_TRADE_COMMAND_STREAM_MAXLEN=1000

# Notify-only price-action scanner (reads bars:* Redis keys from ctrader-feed)
SCANNER_ENABLED=false
SCANNER_SYMBOLS=XAU
SCANNER_EXEC_TF=M5
SCANNER_HTF=M30,M15
# Optional dedicated bot token for feed-analysis/scanner notifications.
# Unset uses TELEGRAM_BOT_TOKEN.
SCANNER_TELEGRAM_BOT_TOKEN=
SCANNER_WINDOW=500
SCANNER_ALERT_TTL=7200
SCANNER_LEVEL_BUCKET=20
ZONE_ALERT_TTL=14400
SCANNER_CONFLUENCE_FLOOR=2
ALERT_OVERLAP_SUPPRESS=0.5
# Opposite-direction, overlapping detections are a contradiction, not a
# duplicate - see scanner.py::_suppress_overlaps (B1).
SCANNER_CONFLICT_OVERLAP=0.5
SCANNER_CONFLICT_MARGIN=1.0
SPOT_FRESH_SECS=30
# XAU should not move 2% inside one M5 bar; larger gaps are feed data.
SPOT_MAX_DEVIATION_PCT=2.0
MAX_ENTRY_ATR=2.0
MAX_ZONE_WIDTH_ATR=1.5
PROXIMAL_BAND_ATR=0.5
MAX_MERGED_ZONE_ATR=3.0
RANGE_LOOKBACK=50
ATR_LENGTH=14
SWING_FRACTAL_N=2
ZIGZAG_PCT=0.0
ZIGZAG_ATR_MULT=1.0
DISPLACEMENT_ATR_MULT=1.5
ZONE_WIDTH=body
ZONE_MERGE_OVERLAP=0.5
EQUAL_TOL_ATR=0.15
LEVEL_CLUSTER_ATR=0.5
ROUND_STEP=5.0
KEY_LEVEL_MIN_TOUCHES=2
MOMENTUM_LOOKBACK=8
MOMENTUM_BODY_FRAC=0.6
EQ_BAND=0.10
STRICT_PD_GATE=false
SWEEP_BODY_FRAC=0.5
SWEEP_REACT_BARS=3
INDUCEMENT_BAND_ATR=0.3
CHOP_FILTER_ENABLED=true
# Ranges below 4 ATR or contained 24-bar range structure are chop candidates.
CHOP_RANGE_ATR=4.0
CHOP_LOOKBACK=24
CHOP_EDGE_FRAC=0.25
# Significant-swing trendline fit and containment thresholds.
TL_MIN_TOUCHES=3
TL_TOL_ATR=0.3
TL_MAX_SLOPE_ATR=0.15
# Consolidation contraction and accepted box-break thresholds.
COIL_CONTRACT=0.8
BREAKOUT_BUFFER_ATR=0.1
BREAKOUT_ACCEPT_BARS=2
BREAKOUT_MAX_AGE_BARS=6
# Owner Market Map assembly and automatic DM delivery.
MAP_MAX_PER_SIDE=4
MAP_MAJOR_SCORE=12
MAP_MAX_TOUCHES=2
MAP_MIN_ZONE_SCORE=6
MAP_MIN_LEVEL_TOUCHES=4
MAP_MAX_DISTANCE_ATR=15
# Keep display bands thin, fill both map sides, and expose near-price scalp rails.
MAP_BAND_MAX_ATR=2.0
MAP_MIN_PER_SIDE=2
MAP_FALLBACK_RADIUS=30.0
MAP_SCALP_RADIUS=15.0
MAP_CHANGE_MIN=1.0
MAP_SESSION_SEND=true
# Evaluate the board once per interval; unchanged maps are not resent.
MAP_SCAN_INTERVAL_MINUTES=60
ALLOW_COUNTER_TREND=true
COUNTER_MIN_ZONE_SCORE=10
COUNTER_EXTREME_PD=0.25
COUNTER_LEVEL_MIN_TOUCHES=3
# Two-sided local-range barrier detection and scalp entry confirmation.
RANGE_SCALP_ENABLED=true
RANGE_SCALP_LOOKBACK=48
RANGE_SCALP_CLUSTER_ATR=0.25
RANGE_SCALP_MIN_TOUCHES=2
RANGE_SCALP_MIN_WICK_FRAC=0.25
RANGE_SCALP_ENTRY_TOL_ATR=0.25
RANGE_SCALP_MIN_WIDTH_ATR=1.0
RANGE_SCALP_MAX_WIDTH_ATR=6.0
RANGE_SCALP_MIN_ROOM_ATR=0.75
RANGE_SCALP_BREAK_CLOSES=2
RANGE_SCALP_MIN_WICK_REJECTIONS=1
RANGE_SCALP_ALLOW_REJECTION_ONLY=true

# PostgreSQL connection (asyncpg/libpq DSN). With the bundled docker-compose
# Postgres service, host is the service name "postgres".
DATABASE_URL=postgresql://apexvoid:apexvoid@postgres:5432/signals
# Used only by the bundled Postgres service in docker-compose.
POSTGRES_USER=apexvoid
POSTGRES_PASSWORD=apexvoid
POSTGRES_DB=signals

# Optional
LOG_LEVEL=INFO
